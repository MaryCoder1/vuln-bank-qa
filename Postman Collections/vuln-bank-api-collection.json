									"let jsondata = pm.response.json()\r",
									"\r",
									"pm.test(\"balance of a newly created user is 1000 by default\", function() {\r",
									"    pm.expect(jsondata.debug_data.balance).to.equal(1000)\r",
									"})\r",
									"\r",
									"pm.environment.set(\"username\",jsondata.debug_data.username)\r",
									"pm.environment.get(\"username\")"
								],
